# Seller accounts (comma-separated, format: email:app_password:client_id)
# Only QQ and 163/126 mailboxes are supported for email verification
SELLER_ACCOUNTS=your@qq.com:app_password:client_id,another@163.com:app_password2:client_id2

# Chrome
CHROME_BIN=/usr/bin/google-chrome-stable
CDP_PORT=9223
XVFB_DISPLAY=:99
