# Seller accounts (comma-separated, format: email:app_password:client_id)
# Multiple accounts supported for rotation when rate-limited
SELLER_ACCOUNTS=your@email.com:app_password:client_id,another@email.com:app_password2:client_id2

# Chrome
CHROME_BIN=/usr/bin/google-chrome-stable
CDP_PORT=9223
XVFB_DISPLAY=:99
